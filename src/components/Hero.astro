---
interface Props {
  hero: {
    headline: string;
    subtitle: string;
    cta: string;
    subtext: string;
  };
}

const { hero } = Astro.props;
---

<section class="relative flex flex-col items-center justify-center text-center text-white overflow-hidden h-[360px] sm:h-[440px] lg:h-[520px]"
  style="background: linear-gradient(135deg, #5a1a17 0%, #B8342E 40%, #d4574f 100%);"
>
  <div class="absolute inset-0 bg-[#1A1A1A]/40"></div>
  <div class="absolute inset-x-0 bottom-0 h-24 bg-gradient-to-t from-bg to-transparent"></div>

  <div class="relative z-10 px-4 max-w-2xl">
    <h1 class="text-4xl sm:text-[42px] lg:text-5xl font-light tracking-[2px] leading-tight mb-2">
      {hero.headline}
    </h1>
    {hero.subtitle && (
      <p class="text-lg sm:text-xl font-light opacity-90 mb-8">{hero.subtitle}</p>
    )}
    <a
      href="#visit"
      class="inline-block px-9 py-3.5 bg-white text-primary font-medium text-base tracking-[0.5px] rounded-md no-underline transition-all duration-150 hover:bg-primary hover:text-white hover:scale-[1.02]"
    >
      {hero.cta}
    </a>
    <p class="mt-3 text-sm opacity-80">{hero.subtext}</p>
  </div>
</section>
