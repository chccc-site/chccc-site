---
import { localePath, langToggleHref, type Locale } from '../lib/i18n';

interface Props {
  nav: {
    churchName: string;
    churchNameEn: string;
    home: string;
    about: string;
    sermons: string;
    news: string;
    giving: string;
    contact: string;
    langToggle: string;
    langToggleHref: string;
    menuLabel: string;
  };
  locale: Locale;
}

const { nav, locale } = Astro.props;
const currentPath = Astro.url.pathname;

const links = [
  { label: nav.about, href: localePath(locale, 'about') },
  { label: nav.sermons, href: localePath(locale, 'sermons') },
  { label: nav.news, href: localePath(locale, 'news') },
  { label: nav.giving, href: localePath(locale, 'giving') },
  { label: nav.contact, href: localePath(locale, 'contact') },
];

const toggleHref = langToggleHref(currentPath, locale);
const homePath = localePath(locale, '');

function isActive(href: string): boolean {
  // Normalize both paths for comparison
  const clean = (p: string) => p.replace(/\/+$/, '');
  return clean(currentPath).startsWith(clean(href));
}
---

<nav aria-label="Main navigation" class="sticky top-0 z-50 bg-surface border-b border-border">
  <div class="max-w-[1200px] mx-auto px-4 sm:px-8 flex items-center justify-between h-16">
    <div class="flex-shrink-0">
      <a href={homePath} class="text-text no-underline">
        <span class="text-lg font-medium leading-tight block">{nav.churchName}</span>
        {nav.churchNameEn && (
          <span class="text-xs text-text-light block">{nav.churchNameEn}</span>
        )}
      </a>
    </div>

    <div class="hidden sm:flex items-center gap-6">
      {links.map(({ label, href }) => (
        <a
          href={href}
          class:list={[
            'text-[15px] font-medium no-underline transition-colors duration-150',
            isActive(href)
              ? 'text-text border-b-2 border-primary pb-0.5'
              : 'text-text-light hover:text-text',
          ]}
        >
          {label}
        </a>
      ))}
      <a
        href={toggleHref}
        class="text-[13px] text-text-light border border-border rounded px-3 py-1 hover:text-text hover:border-text transition-colors duration-150 no-underline"
      >
        {nav.langToggle}
      </a>
    </div>

    <div class="flex sm:hidden items-center gap-3">
      <a
        href={toggleHref}
        class="text-[13px] text-text-light border border-border rounded px-3 py-1 no-underline"
      >
        {nav.langToggle}
      </a>
      <button
        id="menu-toggle"
        type="button"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label={nav.menuLabel}
        class="w-11 h-11 flex items-center justify-center text-text"
      >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line x1="3" y1="6" x2="21" y2="6" class="menu-line-top" />
          <line x1="3" y1="12" x2="21" y2="12" class="menu-line-mid" />
          <line x1="3" y1="18" x2="21" y2="18" class="menu-line-bot" />
        </svg>
      </button>
    </div>
  </div>

  <div
    id="mobile-menu"
    class="sm:hidden fixed inset-0 top-16 bg-surface z-40 flex flex-col items-center justify-center gap-8 transition-all duration-200 ease-out"
    style="display:none;"
  >
    {links.map(({ label, href }) => (
      <a
        href={href}
        class:list={[
          'text-xl font-medium no-underline py-2 mobile-nav-link',
          isActive(href) ? 'text-primary' : 'text-text',
        ]}
      >
        {label}
      </a>
    ))}
  </div>
</nav>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      const expanded = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!expanded));
      menu.style.display = expanded ? 'none' : 'flex';
    });
    menu.querySelectorAll('.mobile-nav-link').forEach((link) => {
      link.addEventListener('click', () => {
        toggle.setAttribute('aria-expanded', 'false');
        menu.style.display = 'none';
      });
    });
  }
</script>
