---
import Layout from '../layouts/Layout.astro';
import Nav from './Nav.astro';
import Footer from './Footer.astro';
import { loadStrings, type Locale } from '../lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const s = await loadStrings(locale);
---

<Layout title={`${s.givingPage.heading} | ${s.title}`} description={s.description} lang={s.lang} htmlLang={s.htmlLang} skipToContent={s.skipToContent}>
  <Nav nav={s.nav} locale={locale} />
  <main id="main-content">
    <section class="py-14 sm:py-20">
      <div class="text-center max-w-[600px] mx-auto px-4 sm:px-8 section-animate">
        <h1 class="text-[28px] font-normal mb-6">{s.givingPage.heading}</h1>
        <p class="text-base text-text-light mb-8 leading-relaxed">{s.givingPage.body}</p>

        <a
          href="https://www.paypal.com/cgi-bin/webscr?cmd=_s-xclick&hosted_button_id=UWRQYF9QPRYS6"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block bg-primary text-white px-8 py-3 rounded-lg text-lg font-medium hover:bg-primary/90 transition-colors duration-150 no-underline"
        >
          {s.givingPage.paypalButton}
        </a>

        <div class="border-t border-border my-8"></div>

        <h2 class="text-lg font-medium mb-3">{s.givingPage.checkHeading}</h2>
        <p class="text-sm text-text-light mb-2">{s.givingPage.checkBody}</p>
        <p class="text-sm text-text-light">{s.givingPage.mailAddress}</p>
      </div>
    </section>
  </main>
  <Footer footer={s.footer} locale={locale} />
</Layout>
