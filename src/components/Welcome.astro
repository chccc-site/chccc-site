---
interface Props {
  heading: string;
  body: string;
}

const { heading, body } = Astro.props;
---

<section id="welcome" class="py-14 sm:py-20 bg-bg">
  <div class="max-w-[680px] mx-auto px-4 sm:px-8 text-center">
    <h2 class="text-[26px] sm:text-[28px] font-normal text-text leading-snug mb-4">{heading}</h2>
    <p class="text-base text-text-light leading-relaxed">{body}</p>
  </div>
</section>
