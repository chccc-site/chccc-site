---
import NewsDetailPage from '../../../components/NewsDetailPage.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const allAnnouncements = await getCollection('announcements');
  const zhPosts = allAnnouncements.filter((e) => e.id.startsWith('zh/'));

  return zhPosts.map((post) => ({
    params: { slug: post.id.replace('zh/', '').replace(/\.md$/, '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---
<NewsDetailPage
  locale="zh"
  title={post.data.title}
  date={post.data.date}
  image={post.data.image}
  Content={Content}
/>
